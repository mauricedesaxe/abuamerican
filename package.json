{
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "next lint --fix --file"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@headlessui/react": "1.4.2",
    "@heroicons/react": "1.0.5",
    "@tailwindcss/aspect-ratio": "0.3.0",
    "@tailwindcss/forms": "0.5.3",
    "@tanstack/react-query": "4.3.4",
    "axios": "0.27.2",
    "next": "12.1.6",
    "react": "17.0.2",
    "react-dom": "17.0.2"
  },
  "devDependencies": {
    "@types/node": "18.7.18",
    "@types/react": "18.0.20",
    "autoprefixer": "10.2.6",
    "eslint": "8.57.0",
    "eslint-config-next": "12.1.6",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.7",
    "lint-staged": "15.2.10",
    "postcss": "8.3.5",
    "prettier": "3.3.3",
    "tailwindcss": "2.2.4",
    "typescript": "4.8.3"
  }
}
